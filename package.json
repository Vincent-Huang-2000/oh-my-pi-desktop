{
  "name": "oh-my-pi-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop client for oh-my-pi.",
"author": "Vincent Huang",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && tsc -p tsconfig.electron.json && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc --noEmit -p tsconfig.json && tsc -p tsconfig.electron.json && vite build",
    "dist:win": "npm run build && electron-builder --win portable",
    "start": "electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.ohmypi.desktop",
    "productName": "Oh My Pi Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
